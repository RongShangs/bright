<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">

    <LinearLayout
        android:id="@+id/dialogCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog"
        android:orientation="horizontal"
        android:padding="20dp"
        android:elevation="8dp">

        <!-- Left Panel: Info -->
        <LinearLayout
            android:layout_width="160dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/takeoverStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前为系统控制"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/brightnessValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="亮度值 ----/----"
                android:textColor="#666666"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="系统状态"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rootStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Root: 未知"
                android:textColor="#666666"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/developerLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="酷安@戎Shangs"
                android:textColor="#1E88E5"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Middle Panel: Slider -->
        <brightnesslock.rongshangs.top.ui.VerticalBrightnessSlider
            android:id="@+id/brightnessSlider"
            android:layout_width="72dp"
            android:layout_height="240dp"
            android:layout_marginStart="12dp" />

        <!-- Right Panel: Restore Button -->
        <FrameLayout
            android:id="@+id/restoreBtn"
            android:layout_width="88dp"
            android:layout_height="240dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_panel"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="还原\n系统\n控制"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

    </LinearLayout>
</FrameLayout>
